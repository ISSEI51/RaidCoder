# =============================================================================
# RaidCoder Lightsail スタック環境変数(infra/docker-compose.yml 用)
# =============================================================================
# 使い方: cp .env.example .env して実際の値を設定する。
# .env は秘密情報を含むため絶対にコミットしないこと(.gitignore 済み)。
# 変数名は docs/CONTRACT.md §9 が正。

# --- Judge0 API 認証トークン ---------------------------------------------
# 生成例: openssl rand -hex 32
# server コンテナ(AUTHN_TOKEN)と judge-bridge / generator の3者に同じ値が渡る
JUDGE0_AUTH_TOKEN=dummy-judge0-token

# --- Supabase(Dashboard → Project Settings → API)------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
# service_role キー(RLS をバイパスする強権限キー。絶対に公開しない)
SUPABASE_SERVICE_ROLE_KEY=dummy-service-role-key

# --- AI 問題生成(generator)-----------------------------------------------
# 本番は anthropic-api 固定(claude-cli はローカル開発専用)
AI_PROVIDER=anthropic-api
ANTHROPIC_API_KEY=sk-ant-dummy
# 任意で claude-opus-4-8 等に変更可
AI_MODEL=claude-sonnet-5

# --- 任意設定 ---------------------------------------------------------------
# 提出ポーリング間隔(ミリ秒)。未設定なら 2000
# POLL_INTERVAL_MS=2000
